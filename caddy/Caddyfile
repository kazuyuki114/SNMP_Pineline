# DuckDNS domain, HTTP only (không có TLS)
# Đặt DOMAIN=yourname.duckdns.org trong file .env

http://{$DOMAIN} {
    # --- Grafana UI ---
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # --- ClickHouse HTTP API ---
    handle /clickhouse/* {
        uri strip_prefix /clickhouse
        reverse_proxy clickhouse:8123
    }

    # Chặn tất cả route còn lại
    handle {
        respond "Not Found" 404
    }

    encode gzip

    log {
        output file /data/access.log
        format json
    }
}
