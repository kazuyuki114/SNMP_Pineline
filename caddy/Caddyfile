
{$DOMAIN} {
    # --- Grafana UI ---
    redir /grafana /grafana/ 301
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # --- ClickHouse HTTP API (push data, query qua curl) ---
    handle /clickhouse/* {
        uri strip_prefix /clickhouse
        reverse_proxy clickhouse:8123
    }

    handle /play* {
        reverse_proxy clickhouse:8123
    }
    handle /js/* {
        reverse_proxy clickhouse:8123
    }
    handle /css/* {
        reverse_proxy clickhouse:8123
    }
    handle /favicon.ico {
        reverse_proxy clickhouse:8123
    }

    @ch_api {
        query add_http_cors_header=*
    }
    handle @ch_api {
        reverse_proxy clickhouse:8123
    }

    handle {
        respond "Not Found" 404
    }

    encode gzip

    log {
        output file /data/access.log
        format json
    }
}
